<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pünktlichkeitsstatistik</title>
    <script src="/dist/js/convertions.js"></script>
    <script src="/dist/js/lib/chart.js"></script>
    <style>
      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        height: 100vh;
        margin: 0;
        background-color: #f4f4f9;
        overflow: hidden;
      }

      .controls {
        margin: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: flex-end;
        background: white;
        padding: 15px;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
      }

      .controls div {
        display: flex;
        flex-direction: column;
      }

      label {
        font-size: 11px;
        margin-bottom: 4px;
        color: #666;
        font-weight: bold;
      }

      .controls input,
      .controls select,
      .controls button {
        height: 35px;
        padding: 5px;
        font-size: 14px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
      }

      button {
        background: #007bff;
        color: white;
        cursor: pointer;
        border: none !important;
        padding: 0 20px !important;
      }

      button:disabled {
        background: #ccc;
      }

      /* Unified Stats Style */
      .db-stats {
        width: 90vw;
        font-size: 11px;
        color: #555;
        background: #e9ecef;
        padding: 5px 15px;
        border-radius: 4px;
        margin-bottom: 5px;
        display: flex;
        gap: 20px;
        font-family: monospace;
      }
      .db-stats b {
        color: #007bff;
      }

      footer {
        position: fixed;
        z-index: 1000;
        bottom: 0;
        left: 0;
        width: 100%;
        background: #333;
        color: #fff;
        text-align: center;
        height: 30px;
        font-size: 0.8em;
        line-height: 30px;
      }
      footer a {
        color: #fff;
      }
    </style>
  </head>
  <body>
    <div class="db-stats" id="dbStats">
      <span>Rows Read: <b id="statRows">-</b></span>
      <span>Speed: <b id="statSpeed">-</b> rows/s</span>
      <span>Duration: <b id="statTime">-</b> ms</span>
    </div>

    <div class="controls">
      <div>
        <label>Time Range:</label>
        <select id="timeRangeSelect">
          <option value="month">Month</option>
          <option value="week">Week</option>
        </select>
      </div>

      <div>
        <label>Select Percentage:</label>
        <select id="percentageSelect">
          <option value="percentage_early">Early</option>
          <option value="percentage_on_time">On Time</option>
          <option value="percentage_late">Late</option>
        </select>
      </div>

      <div>
        <label>Outer Neg (min):</label>
        <input style="width: 70px" id="outerNegBound" type="number" value="-15" />
      </div>

      <div>
        <label>Lower Inner (min):</label>
        <input style="width: 70px" id="lowerInnerBound" type="number" value="-1" />
      </div>

      <div>
        <label>Upper Inner (min):</label>
        <input style="width: 70px" id="upperInnerBound" type="number" value="3" />
      </div>

      <div>
        <label>Outer Pos (min):</label>
        <input style="width: 70px" id="outerPosBound" type="number" value="15" />
      </div>

      <div>
        <label>Years:</label>
        <input style="width: 60px" id="years" type="number" value="1" min="1" max="10" />
      </div>

      <div>
        <button id="fetchDataButton" onclick="fetchAndRenderData()">Lade Daten</button>
      </div>
    </div>

    <div style="width: 95vw; height: 75vh">
      <canvas id="linechart"></canvas>
    </div>

    <footer>
      <p><%= appName %>@<%= commitId %> <a href="https://github.com/Public-Transport-Nuremberg/VAGStatsTracker">Source</a> <a href="/legal/legal">Imprint</a></p>
    </footer>

    <script>
      const fetchDataButton = document.getElementById("fetchDataButton");
      const ctx = document.getElementById("linechart").getContext("2d");
      let chart;
      let cachedData = [];

      document.getElementById("percentageSelect").addEventListener("change", () => {
        if (cachedData.length > 0) {
          updateChart();
        }
      });

      async function fetchAndRenderData() {
        fetchDataButton.disabled = true;
        fetchDataButton.textContent = "Loading...";

        const timeRange = document.getElementById("timeRangeSelect").value;
        const apiUrl = `/api/v1/statistics/delay/percentage/${timeRange}/product?outerNegBound=${document.getElementById("outerNegBound").value * 60}&lowerInnerBound=${document.getElementById("lowerInnerBound").value * 60}&upperInnerBound=${document.getElementById("upperInnerBound").value * 60}&outerPosBound=${document.getElementById("outerPosBound").value * 60}&years=${document.getElementById("years").value}`;

        try {
          const response = await fetch(apiUrl);
          if (!response.ok) throw new Error("Failed to fetch data");

          const body = await response.json();

          cachedData = body.data || body;
          const summary = body.summary;

          if (summary) {
            updatePerformanceUI(summary);
          }

          updateChart();
        } catch (error) {
          console.error("Error fetching data:", error);
          alert("Failed to fetch data.");
        } finally {
          fetchDataButton.disabled = false;
          fetchDataButton.textContent = "Lade Daten";
        }
      }

      function updatePerformanceUI(summary) {
        document.getElementById("dbStats").style.display = "flex";

        const rows = parseInt(summary.read_rows) || 0;
        const ns = parseInt(summary.elapsed_ns) || 0;

        document.getElementById("statRows").textContent = rows.toLocaleString();
        document.getElementById("statTime").textContent = (ns / 1e6).toFixed(2);

        if (ns > 0) {
          const rps = rows / (ns / 1e9);
          document.getElementById("statSpeed").textContent = Math.round(rps).toLocaleString();
        }
      }

      function updateChart() {
        const selectedPercentage = document.getElementById("percentageSelect").value;
        const timeRange = document.getElementById("timeRangeSelect").value;

        const datasets = [1, 2, 3].map((produkt) => {
          const filteredData = cachedData.filter((item) => item.produkt === produkt);
          return {
            label: `${convertIntToProduct(produkt)}`,
            data: filteredData.map((item) => parseFloat(item[selectedPercentage])),
            borderColor: getProductColor(convertIntToProduct(produkt)),
            backgroundColor: getProductColor(convertIntToProduct(produkt)),
            tension: 0.2,
            fill: false,
          };
        });

        if (chart) chart.destroy();

        const maxPercentage = Math.max(...datasets.flatMap((dataset) => dataset.data), 1);
        const yAxisMax = Math.min(Math.ceil(maxPercentage * 1.5), 100);

        const uniqueLabels = Array.from(new Set(cachedData.map((item) => (timeRange === "month" ? new Date(item.month).toLocaleDateString(undefined, { month: "2-digit", year: "numeric" }) : `W${item.calendar_week}, ${item.year}`)))).reverse();

        chart = new Chart(ctx, {
          type: "line",
          data: {
            labels: uniqueLabels,
            datasets: datasets,
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: {
                beginAtZero: true,
                max: yAxisMax,
                ticks: {
                  callback: (value) => value + "%",
                },
              },
            },
          },
        });
      }

      function getProductColor(produkt) {
        switch (produkt) {
          case "Bus":
            return "rgb(255, 99, 132)";
          case "Tram":
            return "rgb(54, 162, 235)";
          case "UBahn":
            return "rgb(75, 192, 192)";
          default:
            return "rgb(255, 205, 86)";
        }
      }
    </script>
  </body>
</html>
