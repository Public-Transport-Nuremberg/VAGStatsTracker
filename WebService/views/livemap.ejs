<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta charset="UTF-8" />
    <title>VGN Livemap</title>
    <script src="/dist/js/ol.js"></script>
    <script src="/dist/js/lib/geolib.js" type="text/javascript"></script>
    <link rel="stylesheet" href="/dist/css/tailwind.css" />
    <link rel="stylesheet" href="/dist/css/ol.css" />
    <link rel="stylesheet" href="/dist/css/popup.css" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
      }

      .map {
        z-index: 1;
      }
    </style>
  </head>
  <body class="overflow-hidden">
    <div id="map" class="map vag-map"></div>
    <div class="fixed left-3 top-3 z-20 flex max-w-[calc(100vw-1.5rem)] flex-wrap gap-2 sm:left-4 sm:top-4">
      <a href="/" class="vag-button-secondary h-9 px-3 text-xs">Zurück</a>
      <button id="locateButton" class="vag-button h-9 px-3 text-xs" type="button">Alle zeigen</button>
      <span id="liveStatus" class="rounded-md border border-slate-200 bg-white/95 px-3 py-2 text-xs font-semibold text-slate-700 shadow-panel" data-state="idle">Verbinde...</span>
    </div>
    <div id="popup" class="lm-popup">
      <button id="popup-close" class="lm-close" type="button" aria-label="Popup schliessen">x</button>
      <div id="popup-content"></div>
    </div>

    <footer class="vag-footer">
      <p><%= appName %>@<%= commitId %> <a href="https://github.com/Public-Transport-Nuremberg/VAGStatsTracker">Source</a> <a href="/legal/legal">Imprint</a></p>
    </footer>
  </body>
  <script src="/dist/js/livemap_main.js"></script>
</html>
