<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
    <title>Error <%= statusCode %></title>
    <link href="<%= domain %>/dist/css/tailwind.css" rel="stylesheet"/>
  </head>
  <body class="vag-page flex min-h-screen items-center justify-center px-4">
    <div class="vag-panel max-w-lg text-center">
          <div class="text-6xl font-bold text-vag-blue"><%= statusCode %></div>
          <p class="mt-3 text-xl font-semibold text-slate-950"><%= message %></p>
          <p class="mt-2 text-sm text-slate-600">
            <%= info %>
          </p>
          <p class="mt-2 text-sm text-slate-700"><%= reason %></p>
          <div class="mt-5">
            <a href="<%= back_url %>" class="vag-button gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
              Take me back
            </a>
          </div>
    </div>
  </body>
</html>
