<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Abfahrten - VAG Stats</title>
    <link rel="stylesheet" href="/dist/css/tailwind.css" />
  </head>
  <body class="vag-page">
    <main class="vag-shell">
      <header class="vag-header">
        <div>
          <h1 class="vag-title">Abfahrten</h1>
          <p class="vag-subtitle">Live-Abfahrten mit Fahrzeugdaten für Klimatisierung, Antrieb und Barrierefreiheit.</p>
        </div>
        <a href="/" class="vag-button-secondary">Zurück</a>
      </header>

      <section class="vag-control-bar relative">
        <div class="vag-field min-w-72 flex-1">
          <label class="vag-label" for="stationSearch">Haltestelle</label>
          <input id="stationSearch" class="vag-input" type="search" autocomplete="off" placeholder="Station suchen" />
          <div id="stationResults" class="absolute left-3 right-3 top-24 z-20 hidden max-h-80 overflow-auto rounded-md border border-slate-200 bg-white shadow-panel sm:left-auto sm:right-auto sm:top-16 sm:w-[32rem]"></div>
        </div>
        <div class="vag-field">
          <label class="vag-label" for="productFilter">Produkt</label>
          <select id="productFilter" class="vag-input min-w-36">
            <option value="" selected>Alle</option>
            <option value="UBahn">U-Bahn</option>
            <option value="Tram">Tram</option>
            <option value="Bus">Bus</option>
          </select>
        </div>
        <button id="gpsButton" class="vag-button-secondary" type="button">GPS</button>
        <button id="refreshButton" class="vag-button" type="button">Aktualisieren</button>
      </section>

      <section class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1fr)_18rem]">
        <div class="vag-card overflow-hidden">
          <div class="flex flex-col gap-2 border-b border-slate-200 bg-white px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 id="boardTitle" class="text-lg font-semibold text-slate-950">Keine Haltestelle</h2>
              <p id="boardMeta" class="text-sm text-slate-500">Bereit</p>
            </div>
            <span id="boardStatus" class="inline-flex h-8 items-center rounded-md border border-slate-200 bg-slate-100 px-3 text-xs font-semibold text-slate-600">Idle</span>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm">
              <thead class="hidden bg-slate-100 text-xs uppercase tracking-normal text-slate-500 sm:table-header-group">
                <tr>
                  <th class="px-4 py-3 font-semibold">Zeit</th>
                  <th class="px-4 py-3 font-semibold">Linie</th>
                  <th class="px-4 py-3 font-semibold">Richtung</th>
                  <th class="px-4 py-3 font-semibold">Steig</th>
                  <th class="px-4 py-3 font-semibold">Fahrzeug</th>
                </tr>
              </thead>
              <tbody id="departuresBody" class="divide-y divide-slate-100 bg-white">
                <tr>
                  <td colspan="5" class="px-4 py-8 text-center text-slate-500">Station auswählen</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="vag-panel h-fit">
          <h2 class="text-sm font-semibold uppercase tracking-normal text-slate-500">Station</h2>
          <dl class="mt-3 grid gap-3 text-sm">
            <div>
              <dt class="text-xs font-semibold uppercase text-slate-500">Name</dt>
              <dd id="stationName" class="mt-1 text-slate-950">-</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-slate-500">VGN</dt>
              <dd id="stationVgn" class="mt-1 font-mono text-slate-950">-</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-slate-500">VAG</dt>
              <dd id="stationVag" class="mt-1 font-mono text-slate-950">-</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-slate-500">Produkte</dt>
              <dd id="stationProducts" class="mt-1 text-slate-950">-</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-slate-500">Distanz</dt>
              <dd id="stationDistance" class="mt-1 text-slate-950">-</dd>
            </div>
          </dl>
        </aside>
      </section>
    </main>

    <footer class="vag-footer">
      <p><%= appName %>@<%= commitId %> <a href="https://github.com/Public-Transport-Nuremberg/VAGStatsTracker">Source</a> <a href="/legal/legal">Imprint</a></p>
    </footer>
    <script src="/dist/js/departures.js?v=20260630-6"></script>
  </body>
</html>
