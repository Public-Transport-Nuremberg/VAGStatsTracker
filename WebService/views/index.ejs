<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VAG Stats</title>
    <link rel="stylesheet" href="/dist/css/tailwind.css" />
  </head>
  <body class="vag-page">
    <main class="vag-shell">
      <header class="vag-header">
        <div>
          <h1 class="vag-title">VAG Stats</h1>
          <p class="vag-subtitle">Livekarten, Verspaetungen und Fahrzeugverlaeufe fuer den Nahverkehr in Nuernberg.</p>
        </div>
      </header>

      <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/livemap">
          <img class="aspect-video w-full object-cover" src="/dist/img/318438398-1b42237a-1d7c-4da9-9092-963dad3c6972.webp" alt="Livemap" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Livemap</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Aktuelle Fahrzeugpositionen mit Linie, Richtung, Halten und Fahrzeugdetails.</p>
          </div>
        </a>

        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/heatmap">
          <img class="aspect-video w-full object-cover" src="/dist/img/318444039-a6953e61-28fb-4892-83ab-2da07ac3c001.webp" alt="Heatmap" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Heatmap</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Durchschnittliche Verspaetungen an Stationen fuer einen ausgewaehlten Tag.</p>
          </div>
        </a>

        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/linestats">
          <img class="aspect-video w-full object-cover" src="/dist/img/linestats.webp" alt="Linienstatistik" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Linienstatistik</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Ankunfts- und Abfahrtsverzoegerung je Station, Linie und Stunde.</p>
          </div>
        </a>

        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/livemap">
          <img class="aspect-video w-full object-cover" src="/dist/img/vehicleHistory.webp" alt="Fahrzeughistorie" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Fahrzeughistorie</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Historische Halte und Tagesstrecken direkt aus einem Livemap-Fahrzeug oeffnen.</p>
          </div>
        </a>

        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/ontimelinechart">
          <img class="aspect-video w-full object-cover" src="/dist/img/ProductLineChart.webp" alt="Puenktlichkeitsstatistik" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Puenktlichkeit</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Wochen- und Monatswerte nach Produkt als Liniendiagramm.</p>
          </div>
        </a>

        <a class="vag-card group overflow-hidden no-underline transition hover:-translate-y-0.5 hover:shadow-panel" href="/histogram">
          <img class="aspect-video w-full object-cover" src="/dist/img/Histogram.webp" alt="Histogramm" />
          <div class="p-4">
            <h2 class="text-lg font-semibold text-slate-950">Histogramm</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">Verteilung der Verspaetungen mit Vergleich mehrerer Zeitraeume.</p>
          </div>
        </a>
      </section>
    </main>

    <footer class="vag-footer">
      <p><%= appName %>@<%= commitId %> <a href="https://github.com/Public-Transport-Nuremberg/VAGStatsTracker">Source</a> <a href="/legal/legal">Imprint</a></p>
    </footer>
  </body>
</html>
