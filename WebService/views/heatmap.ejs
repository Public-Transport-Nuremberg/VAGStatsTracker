<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta charset="UTF-8" />
    <title>VGN Heatmap</title>
    <script src="/dist/js/ol.js"></script>
    <script src="/dist/js/lib/geolib.js" type="text/javascript"></script>
    <link rel="stylesheet" href="/dist/css/tailwind.css" />
    <link rel="stylesheet" href="/dist/css/ol.css" />
    <style>
      .map {
        z-index: 1; /* Make sure this is behind any other positioned elements */
      }
    </style>
  </head>
  <body class="overflow-hidden">
    <div id="map" class="map vag-map"></div>
    <a href="/" class="vag-button-secondary fixed left-3 top-3 z-20 h-9 px-3 text-xs no-underline sm:left-4 sm:top-4">Zurück</a>
    <div id="heatmap-legend" class="vag-map-panel fixed bottom-12 left-3 z-20 w-[min(16rem,calc(100vw-1.5rem))] sm:left-5">
      <h4 class="mb-2 text-sm font-semibold text-slate-950">Heatmap Legende</h4>
      <div id="legend-bar" class="h-5 w-full rounded border border-slate-900"></div>
      <div class="mt-1 flex justify-between text-xs text-slate-600">
        <span id="legend-min">Min</span>
        <span id="legend-max">Max</span>
      </div>
    </div>
    <footer class="vag-footer">
      <p><%= appName %>@<%= commitId %> <a href="https://github.com/Public-Transport-Nuremberg/VAGStatsTracker">Source</a> <a href="/legal/legal">Imprint</a></p>
    </footer>
  </body>
  <script src="/dist/js/heatmap.js"></script>
</html>
